<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <!-- OpenGL camera preview (full screen behind controls) -->
    <com.cineshot.app.gl.CineGLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top bar: Dolly Zoom controls + Stabiliser toggle -->
    <LinearLayout
        android:id="@+id/dollyBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/preset_bar_bg"
        android:paddingStart="6dp"
        android:paddingEnd="2dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            style="@style/ControlLabel"
            android:text="强度" />

        <SeekBar
            android:id="@+id/dollyIntensitySeekbar"
            android:layout_width="80dp"
            android:layout_height="24dp"
            android:max="100"
            android:progress="80"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVertigo"
            style="@style/PresetButton"
            android:text="眩晕变焦"
            android:layout_marginStart="2dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#44FFFFFF"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStabilizer"
            style="@style/PresetButton"
            android:text="关" />

    </LinearLayout>

    <!-- Cinematic preset bar (bottom) -->
    <LinearLayout
        android:id="@+id/presetBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/preset_bar_bg"
        android:padding="8dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPushIn"
            style="@style/PresetButton"
            android:text="推近" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPullOut"
            style="@style/PresetButton"
            android:text="拉远" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnParallaxPan"
            style="@style/PresetButton"
            android:text="环绕" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCraneUp"
            style="@style/PresetButton"
            android:text="摇臂" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            style="@style/PresetButton"
            android:text="复位" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
